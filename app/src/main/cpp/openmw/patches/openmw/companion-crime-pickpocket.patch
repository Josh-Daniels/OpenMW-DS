     ContainerWindow::ContainerWindow(DragAndDrop& dragAndDrop, ItemTransfer& itemTransfer)
         : WindowBase("openmw_container_window.layout")
@@ -64,6 +72,30 @@ namespace MWGui
         mControllerButtons.mX = "#{Interface:TakeAll}";
         mControllerButtons.mR3 = "#{Interface:Info}";
         mControllerButtons.mL2 = "#{Interface:Inventory}";
+
+        gCompanionContainerWindow = this;
+    }
+
+    // COMPANION (OpenMW-DS): route a DS-side pickpocket take through the native item model's
+    // onTakeItem -- the exact vanilla per-take flow: Pickpocket::pick roll (value-scaled catch chance)
+    // -> on DETECT: commitCrime(OT_Pickpocket, victimAware) + set mPickpocketDetected + pop GM_Container;
+    // -> on SUCCESS: award Sneak XP + itemTaken(alarm=false) (flag stolen, no second crime). The DS UI
+    // moves items via Lua moveInto and never touches this window's onTakeItem, so all of that was
+    // bypassed. Setting mPickpocketDetected natively is also what stops the on-close finish() roll
+    // (companion-hide-container-on-hideui.patch Hunk 3) from DOUBLE-committing after a detected take.
+    // Returns true if the take is ALLOWED (the caller should transfer the item), false if DETECTED
+    // (deny the take; the model already committed the crime and popped the container mode, so the DS
+    // overlay closes via UiModeChanged). Guarded so it is inert unless a container mode is really open.
+    bool companionPickpocketTake(const MWWorld::Ptr& item, int count)
+    {
+        if (!gCompanionContainerWindow)
+            return true;
+        if (!MWBase::Environment::get().getWindowManager()->containsMode(GM_Container))
+            return true;
+        ItemModel* model = gCompanionContainerWindow->getModel();
+        if (!model)
+            return true;
+        return model->onTakeItem(item, count);
     }
 
     void ContainerWindow::onItemSelected(int index)

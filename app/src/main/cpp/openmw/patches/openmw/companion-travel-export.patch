+
+        // Every child of mDestinationsView is a destination button (clearDestinations destroys them
+        // all, addDestination adds only these), in transport order. Read back the UserStrings
+        // addDestination already set — including the merchant-adjusted price — so nothing is
+        // recomputed. Streamed one small line each (OPEN/DEST*/END) for 4096-byte flush safety.
+        const std::size_t n = mDestinationsView->getChildCount();
+        for (std::size_t i = 0; i < n; ++i)
+        {
+            MyGUI::Widget* dest = mDestinationsView->getChildAt(i);
+            const std::string_view name = dest->getUserString("Destination");
+            const int price = Misc::StringUtils::toNumeric<int>(dest->getUserString("price"), 0);
+            const bool interior = dest->getUserString("interior") == "y";
+            // index|destinationName|cost|interior(1/0)
+            Log(Debug::Info) << "COMPANION_TRAVEL_DEST:" << i << "|" << companionTravelSanitize(name) << "|"
+                             << price << "|" << (interior ? 1 : 0);
+        }
+        Log(Debug::Info) << "COMPANION_TRAVEL_END";
+
+        gCompanionTravelSessionOpen = true;
+    }
+
+    void TravelWindow::companionTravelByIndex(int index)

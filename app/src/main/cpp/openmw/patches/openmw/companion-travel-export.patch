+
+// Companion (bottom-screen travel): extern "C" bridges driven from drainCompanionCommands
+// (androidmain.cpp, engine main thread). Mirror the merchant-repair bridges. Each no-ops unless a
+// travel session is actually live (containsMode guard, stale-window safe).
+extern "C" void companionTravelGo(int index)
+{
+    if (!gCompanionTravelWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Travel))
+        return;
+    gCompanionTravelWindow->companionTravelByIndex(index);
+}
+
+extern "C" void companionTravelCancel()
+{
+    if (!gCompanionTravelWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Travel))
+        return;
+    // Pop the mode. In DS mode the window is already hidden, so the mode-pop's setVisible(false) is
+    // a no-op that never fires onClose(); emit the close signal explicitly (once-guarded).
+    MWBase::Environment::get().getWindowManager()->removeGuiMode(MWGui::GM_Travel);
+    companionEmitTravelClosed();
+}

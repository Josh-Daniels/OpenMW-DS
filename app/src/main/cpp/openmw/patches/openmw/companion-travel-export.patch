+    void TravelWindow::companionExportOpen()
+    {
+        if (mPtr.isEmpty())
+            return;
+
+        MWWorld::Ptr player = MWBase::Environment::get().getWorld()->getPlayerPtr();
+        const int playerGold
+            = player.getClass().getContainerStore(player).count(MWWorld::ContainerStore::sGoldId);
+
+        Log(Debug::Info) << "COMPANION_TRAVEL_OPEN:" << companionTravelSanitize(mPtr.getClass().getName(mPtr));

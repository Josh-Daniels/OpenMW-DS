+    // ================= Companion (bottom-screen merchant repair) =================
+
+    void MerchantRepair::companionExportOpen()
+    {
+        if (mActor.isEmpty())
+            return;
+
+        MWWorld::Ptr player = MWMechanics::getPlayer();
+        const int playerGold
+            = player.getClass().getContainerStore(player).count(MWWorld::ContainerStore::sGoldId);
+
+        Log(Debug::Info) << "COMPANION_REPAIR_OPEN:" << companionRepairSanitize(mActor.getClass().getName(mActor));
+        Log(Debug::Info) << "COMPANION_PLAYER_GOLD:" << playerGold;
+
+        // Streamed one small line each (START/ITEM*/END) to stay clear of the 4096-byte
+        // stdout-flush truncation that bites single long COMPANION_ lines.
+        const std::vector<CompanionRepairEntry> damaged = companionCollectDamaged(mActor);
+        for (std::size_t i = 0; i < damaged.size(); ++i)
+        {
+            const CompanionRepairEntry& e = damaged[i];
+            // name|sid|condition|maxCondition|repairCost   (sid = ordinal index)
+            Log(Debug::Info) << "COMPANION_REPAIR_ITEM:" << companionRepairSanitize(e.name) << "|" << i << "|"
+                             << e.condition << "|" << e.maxCondition << "|" << e.price;
+        }
+        Log(Debug::Info) << "COMPANION_REPAIR_END";
+
+        gCompanionRepairSessionOpen = true;
+    }
+
+    void MerchantRepair::companionRepairByIndex(int index)
+    {
+        if (mActor.isEmpty())
+            return;
+
+        const std::vector<CompanionRepairEntry> damaged = companionCollectDamaged(mActor);
+        if (index < 0 || index >= static_cast<int>(damaged.size()))
+            return;
+
+        MWWorld::Ptr player = MWMechanics::getPlayer();
+        const int price = damaged[index].price;
+        if (price > player.getClass().getContainerStore(player).count(MWWorld::ContainerStore::sGoldId))
+            return; // can't afford — ignore (the bottom screen also gates this)
+
+        // Mirror onRepairButtonClick: fully restore condition, restack, pay, credit the NPC.
+        MWWorld::Ptr item = damaged[index].item;
+        item.getCellRef().setCharge(item.getClass().getItemMaxHealth(item));
+        player.getClass().getContainerStore(player).restack(item);
+        MWBase::Environment::get().getWindowManager()->playSound(ESM::RefId::stringRefId("Repair"));
+        player.getClass().getContainerStore(player).remove(MWWorld::ContainerStore::sGoldId, price);
+
+        MWMechanics::CreatureStats& actorStats = mActor.getClass().getCreatureStats(mActor);
+        actorStats.setGoldPool(actorStats.getGoldPool() + price);
+
+        companionExportOpen(); // re-export the now-shorter list + updated gold
+    }
+
+    void MerchantRepair::companionRepairAll()
+    {
+        if (mActor.isEmpty())
+            return;
+
+        MWWorld::Ptr player = MWMechanics::getPlayer();
+        bool repairedAny = false;
+
+        // Repair one affordable item per pass, then recollect: setCharge + restack can
+        // merge/invalidate stacks, and each repair lowers the player's gold, so the affordable
+        // set must be recomputed rather than iterated over a stale snapshot.
+        for (;;)
+        {
+            const std::vector<CompanionRepairEntry> damaged = companionCollectDamaged(mActor);
+            const int gold
+                = player.getClass().getContainerStore(player).count(MWWorld::ContainerStore::sGoldId);
+            MWWorld::Ptr item;
+            int price = 0;
+            for (const CompanionRepairEntry& e : damaged)
+            {
+                if (e.price <= gold)
+                {
+                    item = e.item;
+                    price = e.price;
+                    break;
+                }
+            }
+            if (item.isEmpty())
+                break; // nothing else affordable
+
+            item.getCellRef().setCharge(item.getClass().getItemMaxHealth(item));
+            player.getClass().getContainerStore(player).restack(item);
+            player.getClass().getContainerStore(player).remove(MWWorld::ContainerStore::sGoldId, price);
+            MWMechanics::CreatureStats& actorStats = mActor.getClass().getCreatureStats(mActor);
+            actorStats.setGoldPool(actorStats.getGoldPool() + price);
+            repairedAny = true;
+        }
+
+        if (repairedAny)
+            MWBase::Environment::get().getWindowManager()->playSound(ESM::RefId::stringRefId("Repair"));
+        companionExportOpen();
+    }

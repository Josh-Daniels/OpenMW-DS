 #include "../mwworld/containerstore.hpp"
 #include "../mwworld/esmstore.hpp"
 
+namespace
+{
+    // ================= Companion (bottom-screen merchant repair) =================
+    // Mirrors the companion barter bridge (companion-barter-export.patch): the native
+    // MerchantRepair window is hidden while GM_MerchantRepair is in DS mode
+    // (companion-hide-gamewindows-on-dsmode.patch), and the whole repair flow is driven
+    // from the bottom screen via the extern "C" bridges at the end of this file.
+
+    // The single live MerchantRepair window, set in its constructor, so the bridges can
+    // reach it without touching WindowManager's private members. Mirrors gCompanionTradeWindow.
+    MWGui::MerchantRepair* gCompanionMerchantRepair = nullptr;
+
+    // True between COMPANION_REPAIR_OPEN and COMPANION_REPAIR_CLOSED so the close signal is
+    // emitted exactly once, whichever path ends the session (bottom-screen Cancel bridge, or
+    // B/Escape via exit()). The native window is HIDDEN the moment the mode opens in DS mode,
+    // so the usual visible->hidden onClose() transition never fires — the close must be explicit.
+    bool gCompanionRepairSessionOpen = false;
+
+    void companionEmitRepairClosed()
+    {
+        if (!gCompanionRepairSessionOpen)
+            return;
+        gCompanionRepairSessionOpen = false;
+        Log(Debug::Info) << "COMPANION_REPAIR_CLOSED";
+    }
+
+    // Keep a name safe inside the pipe-delimited COMPANION_REPAIR_ITEM line.
+    std::string companionRepairSanitize(std::string_view s)
+    {
+        std::string out(s);
+        for (char& c : out)
+            if (c == '|' || c == '\n' || c == '\r')
+                c = ' ';
+        return out;
+    }
+
+    // One damaged, repairable item + its merchant repair price. Built exactly like the native
+    // MerchantRepair::setPtr list (same category filter, same price formula, same alphabetical
+    // sort) so an ordinal index into this vector is a stable handle shared by the export and
+    // the repair bridges. GM_MerchantRepair pauses the sim, so the set can't change between an
+    // export and the tap that follows it (only a repair mutates it, and that re-exports).
+    struct CompanionRepairEntry
+    {
+        std::string name;
+        MWWorld::Ptr item;
+        int condition;
+        int maxCondition;
+        int price;
+    };
+
+    std::vector<CompanionRepairEntry> companionCollectDamaged(const MWWorld::Ptr& actor)
+    {
+        std::vector<CompanionRepairEntry> out;
+        if (actor.isEmpty())
+            return out;
+
+        MWWorld::Ptr player = MWMechanics::getPlayer();
+        MWWorld::ContainerStore& store = player.getClass().getContainerStore(player);
+        const int categories = MWWorld::ContainerStore::Type_Weapon | MWWorld::ContainerStore::Type_Armor;
+        const float fRepairMult = MWBase::Environment::get()
+                                      .getESMStore()
+                                      ->get<ESM::GameSetting>()
+                                      .find("fRepairMult")
+                                      ->mValue.getFloat();
+
+        for (MWWorld::ContainerStoreIterator iter(store.begin(categories)); iter != store.end(); ++iter)
+        {
+            if (!iter->getClass().hasItemHealth(*iter))
+                continue;
+            const int maxDurability = iter->getClass().getItemMaxHealth(*iter);
+            const int durability = iter->getClass().getItemHealth(*iter);
+            if (maxDurability <= durability || maxDurability == 0)
+                continue;
+
+            const int basePrice = iter->getClass().getValue(*iter);
+            const float p = static_cast<float>(std::max(1, basePrice));
+            const float r = static_cast<float>(std::max(1, static_cast<int>(maxDurability / p)));
+            int x = static_cast<int>((maxDurability - durability) / r);
+            x = static_cast<int>(fRepairMult * x);
+            x = std::max(1, x);
+            const int price = MWBase::Environment::get().getMechanicsManager()->getBarterOffer(actor, x, true);
+
+            out.push_back(
+                { std::string{ iter->getClass().getName(*iter) }, *iter, durability, maxDurability, price });
+        }
+
+        std::stable_sort(out.begin(), out.end(),
+            [](const CompanionRepairEntry& a, const CompanionRepairEntry& b) {
+                return Misc::StringUtils::ciLess(a.name, b.name);
+            });
+        return out;
+    }
+}

+// Companion (bottom-screen repair): extern "C" bridges driven from drainCompanionCommands
+// (androidmain.cpp, engine main thread). Mirror the barter bridges. Each no-ops unless a
+// merchant-repair session is actually live (containsMode guard, stale-window safe).
+extern "C" void companionRepairItem(int index)
+{
+    if (!gCompanionMerchantRepair)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_MerchantRepair))
+        return;
+    gCompanionMerchantRepair->companionRepairByIndex(index);
+}
+
+extern "C" void companionRepairAll()
+{
+    if (!gCompanionMerchantRepair)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_MerchantRepair))
+        return;
+    gCompanionMerchantRepair->companionRepairAll();
+}
+
+extern "C" void companionRepairCancel()
+{
+    if (!gCompanionMerchantRepair)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_MerchantRepair))
+        return;
+    // Pop the mode. In DS mode the window is already hidden, so the mode-pop's setVisible(false)
+    // is a no-op that never fires onClose(); emit the close signal explicitly (once-guarded).
+    MWBase::Environment::get().getWindowManager()->removeGuiMode(MWGui::GM_MerchantRepair);
+    companionEmitRepairClosed();
+}

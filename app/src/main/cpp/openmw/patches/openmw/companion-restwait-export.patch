+    void WaitDialog::companionExportOpen()
+    {
+        // The date caption was resolved (#{Calendar:*} tags replaced) by onOpen's
+        // setCaptionWithReplacing, so getCaption() returns the final display string,
+        // e.g. "24 Last Seed (Day 9) 10 a.m.". mSleeping distinguishes Rest vs Wait.
+        const std::string dateStr = mDateTimeText->getCaption().asUTF8();

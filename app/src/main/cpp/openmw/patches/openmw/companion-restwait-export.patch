+
+// Companion (bottom-screen rest/wait): extern "C" bridges driven from drainCompanionCommands
+// (androidmain.cpp, engine main thread). Mirror the repair bridges. Each no-ops unless a
+// rest/wait picker is actually live (containsMode guard, stale-window safe).
+extern "C" void companionSleep(int hours)
+{
+    if (!gCompanionWaitDialog)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Rest))
+        return;
+    gCompanionWaitDialog->companionStartWait(hours);
+}
+
+extern "C" void companionSleepCancel()
+{
+    if (!gCompanionWaitDialog)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Rest))
+        return;
+    gCompanionWaitDialog->companionCancelWait();
+}

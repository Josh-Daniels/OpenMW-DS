+
+        // startWaiting drives the native fade + progress bar + time advance (and the sleep
+        // interruption / level-up handling) on the TOP screen; the mode stays GM_Rest until it
+        // finishes. Dismiss the bottom overlay now — the picker's job is done. Once-guarded.
+        companionEmitSleepClosed();
+        startWaiting(hours);
+    }

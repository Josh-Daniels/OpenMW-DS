+#ifdef __ANDROID__
+    // COMPANION: defined in androidmain.cpp. Each returns true when the matching Game UI element
+    // is in DS mode, so the native top-screen window is suppressed (the companion draws it on the
+    // bottom screen). Replaces the old mHudEnabled (Hide UI) gate on these windows.
+    extern "C" bool companionDsConversation();
+    extern "C" bool companionDsLooting();
+    extern "C" bool companionDsBarter();
+#endif

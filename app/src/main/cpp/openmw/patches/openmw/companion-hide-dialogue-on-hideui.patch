     void WindowManager::updateVisible()
     {
         bool loading = (getMode() == GM_Loading || getMode() == GM_LoadingWallpaper);
@@ -648,6 +657,16 @@
         mHud->setVisible(mHudEnabled && !loading);
         // COMPANION: keep floating actor-name tooltips visible even when the HUD is
         // hidden via the Hide UI toggle. update() only shows the focus-object name.
         mToolTips->setVisible(!loading);

+        // COMPANION: hide the dialogue window when Conversation is in DS mode so the
+        // companion (bottom) screen is the sole conversation surface; show the native
+        // window when Conversation is Vanilla (companionDsConversation() false). Gated on
+        // getMode()==GM_Dialogue — the exact condition under which vanilla shows the window
+        // (a pushed service window makes it no longer the top mode, so this leaves it alone
+        // during barter/spells/travel). onClose() is a no-op while GM_Dialogue is still on
+        // the stack, so hiding it mid-conversation does not end the dialogue or clear history.
+        if (mDialogueWindow && getMode() == GM_Dialogue)
+            mDialogueWindow->setVisible(!companionDsConversation() && !loading);

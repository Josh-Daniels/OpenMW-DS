+    // COMPANION: true between COMPANION_SPELLMAKING_OPEN and _CLOSED (Vanilla-only window).
+    static bool sSpellCreationDialogCompanionOpen = false;
+
     void SpellCreationDialog::setPtr(const MWWorld::Ptr& actor)
     {
         if (actor.isEmpty() || !actor.getClass().isActor())
             throw std::runtime_error("Invalid argument in SpellCreationDialog::setPtr");
+
+        sSpellCreationDialogCompanionOpen = true;
+        Log(Debug::Info) << "COMPANION_SPELLMAKING_OPEN";
 
         mPtr = actor;
         mNameEdit->setCaption({});
@@ -621,6 +629,21 @@
     {
         MWBase::Environment::get().getWindowManager()->removeGuiMode(MWGui::GM_SpellCreation);
     }
+
+    void SpellCreationDialog::onClose()
+    {
+        WindowBase::onClose();
+        // COMPANION: emit the close signal only on the real mode-pop (containsMode false),
+        // not on a transient hide, matching TradeWindow::onClose. Lets the bottom-screen
+        // conversation overlay come back once this native window is gone (Vanilla mode).
+        if (sSpellCreationDialogCompanionOpen
+            && !MWBase::Environment::get().getWindowManager()->containsMode(GM_SpellCreation))
+        {
+            sSpellCreationDialogCompanionOpen = false;
+            Log(Debug::Info) << "COMPANION_SPELLMAKING_CLOSED";
+        }
+    }
+
 

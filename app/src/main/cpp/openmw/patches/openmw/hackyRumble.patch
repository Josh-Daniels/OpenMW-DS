Subject: [PATCH] hackyRumble JNI for android.

---
 apps/openmw/mwsound/soundbridge.hpp     | 7 +++++++
 apps/openmw/mwsound/soundmanagerimp.cpp | 4 ++++
 2 files changed, 11 insertions(+)
 create mode 100644 apps/openmw/mwsound/soundbridge.hpp

diff --git a/apps/openmw/mwsound/soundbridge.hpp b/apps/openmw/mwsound/soundbridge.hpp
new file mode 100644
index 0000000000..e85a7ed5c9
--- /dev/null
+++ b/apps/openmw/mwsound/soundbridge.hpp
@@ -0,0 +1,7 @@
+#pragma once
+#include <string>
+
+namespace MWSound
+{
+    extern std::string g_lastResourceName;
+}
diff --git a/apps/openmw/mwsound/soundmanagerimp.cpp b/apps/openmw/mwsound/soundmanagerimp.cpp
index 8471dbe0be..664bc4b3a2 100644
--- a/apps/openmw/mwsound/soundmanagerimp.cpp
+++ b/apps/openmw/mwsound/soundmanagerimp.cpp
@@ -29,12 +29,14 @@
 #include "ffmpegdecoder.hpp"
 #include "openaloutput.hpp"
 #include "sound.hpp"
+#include "soundbridge.hpp"
 #include "soundbuffer.hpp"
 #include "sounddecoder.hpp"
 #include "soundoutput.hpp"
 
 namespace MWSound
 {
+    std::string g_lastResourceName;
     namespace
     {
         constexpr float sMinUpdateInterval = 1.0f / 30.0f;
@@ -498,6 +500,7 @@ namespace MWSound
         SoundBuffer* const sfx = mSoundBuffers.load(fileName);
         if (!sfx)
             return nullptr;
+        MWSound::g_lastResourceName = sfx->getResourceName();
 
         return playSound(sfx, volume, pitch, type, mode, offset);
     }
@@ -566,6 +569,7 @@ namespace MWSound
             it = mActiveSounds.emplace(ptr.mRef, ActiveSound{ ptr.mCell, {} }).first;
         it->second.mList.emplace_back(std::move(sound), sfx);
         mSoundBuffers.use(*sfx);
+        MWSound::g_lastResourceName = sfx->getResourceName();
         return result;
     }
 

@@ -309,5 +309,26 @@
     void HUD::onFrame(float dt)
     {
         LocalMapBase::onFrame(dt);
+#ifdef __ANDROID__
+        // COMPANION: re-apply per-element HUD visibility (native intent & companion
+        // toggle) every frame so On/Off changes take effect live (weapon/sneak are not
+        // re-applied by updateVisible). Crosshair is driven every frame by the camera.
+        mHealth->setVisible(sCompanionHmsNative && companionHudHms());
+        mMagicka->setVisible(sCompanionHmsNative && companionHudHms());
+        mStamina->setVisible(sCompanionHmsNative && companionHudHms());
+        mWeapBox->setVisible(sCompanionWeapNative && companionHudEquipped());
+        mSpellBox->setVisible(sCompanionSpellNative && companionHudEquipped());
+        mMinimapBox->setVisible(sCompanionMinimapNative && companionHudMinimap());
+        mEffectBox->setVisible(sCompanionEffectsNative && companionHudEffects());
+        mSneakBox->setVisible(sCompanionSneakNative && companionHudSneak());
+        // COMPANION: force-hide the target/enemy health bar when toggled off; restore the
+        // +20px mWeaponSpellBox shift (mirrors the vanilla fade-timeout hide) to avoid drift.
+        if (!companionHudEnemy() && mEnemyHealth->getVisible())
+        {
+            mEnemyHealth->setVisible(false);
+            mWeaponSpellBox->setPosition(mWeaponSpellBox->getPosition() + MyGUI::IntPoint(0, 20));
+        }
+        updatePositions();
+#endif
 
         mCellNameTimer -= dt;

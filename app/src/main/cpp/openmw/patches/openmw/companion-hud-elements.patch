     void HUD::setHmsVisible(bool visible)
     {
+#ifdef __ANDROID__
+        sCompanionHmsNative = visible;
+        visible = visible && companionHudHms();
+#endif
         mHealth->setVisible(visible);
         mMagicka->setVisible(visible);

+        // COMPANION (FIX 3b): continuous right-stick scroll of a Vanilla conversation (GM_Dialogue).
+        // Same rationale/pattern as FIX 2 (GM_Scroll): the native DialogueWindow registers its history
+        // ScrollView via getControllerScrollWidget(), but the native right-stick-scroll routing needs
+        // the game cursor, so with the Game cursor OFF a held stick can't scroll it (and its value
+        // leaks into the look channel — see FIX 1). Poll the live axis and nudge the view directly.
+        // Gated on !companionNavActive() so it ONLY drives the native (Vanilla) conversation; when the
+        // conversation is DS the overlay owns scrolling via COMPANION_NAV_SCROLL_* (the poll below).
+        // getMode() == GM_Dialogue (not containsMode) so it doesn't scroll the history behind a service
+        // window (barter/etc.) pushed on top.
+        if (!companionNavActive())
+        {
+            MWBase::WindowManager* dlgWm = MWBase::Environment::get().getWindowManager();
+            if (dlgWm->getMode() == MWGui::GM_Dialogue)
+            {
+                const float ry = getAxisValue(SDL_CONTROLLER_AXIS_RIGHTY);
+                constexpr float threshold = 0.5f;
+                constexpr float interval = 0.06f;
+                static float sDlgScrollAccum = interval; // primed so the first deflection scrolls at once
+                if (ry <= -threshold || ry >= threshold)
+                {
+                    sDlgScrollAccum += dt;
+                    if (sDlgScrollAccum >= interval)
+                    {
+                        sDlgScrollAccum = 0.0f;
+                        const int step = (ry < 0.0f) ? 40 : -40; // stick up = view up (positive offset)
+                        for (MWGui::WindowBase* w : dlgWm->getGuiModeWindows(MWGui::GM_Dialogue))
+                        {
+                            MyGUI::Widget* widget = w ? w->getControllerScrollWidget() : nullptr;
+                            MyGUI::ScrollView* sv
+                                = widget ? widget->castType<MyGUI::ScrollView>(false) : nullptr;
+                            if (sv)
+                                sv->setViewOffset(sv->getViewOffset() + MyGUI::IntPoint(0, step));
+                        }
+                    }
+                }
+                else
+                {
+                    sDlgScrollAccum = interval; // re-arm in the deadzone
+                }
+            }
+        }
 #endif

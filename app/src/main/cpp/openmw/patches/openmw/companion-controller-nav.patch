     void ControllerManager::update(float dt)
     {
+#ifdef __ANDROID__
+        // COMPANION (FIX 1): a DS overlay just closed (companionNavActive true->false) and Kotlin asked
+        // us to reset the sticks. While the menu was open, the stick-release event was SWALLOWED by
+        // gamepadToGuiControl and never reached controllerAxisMoved, so the ICS movement/look channels
+        // can be stuck at their last held value — the player keeps moving/looking after the menu closes.
+        // Inject a neutral (value 0 -> ICS percent ~0.5) event for all four movement/look axes so the
+        // channels return to centre. deviceID 1 matches the SDL pump (sdlinputwrapper.cpp axisMoved(1,…))
+        // and the sFakeDeviceId the axis bindings are registered under (bindingsmanager.cpp).
+        if (companionConsumeResetAxes())
+        {
+            static const SDL_GameControllerAxis kResetAxes[] = { SDL_CONTROLLER_AXIS_LEFTX,
+                SDL_CONTROLLER_AXIS_LEFTY, SDL_CONTROLLER_AXIS_RIGHTX, SDL_CONTROLLER_AXIS_RIGHTY };
+            for (SDL_GameControllerAxis axis : kResetAxes)
+            {
+                SDL_ControllerAxisEvent ev{};
+                ev.type = SDL_CONTROLLERAXISMOTION;
+                ev.which = 1;
+                ev.axis = static_cast<Uint8>(axis);
+                ev.value = 0;
+                mBindingsManager->controllerAxisMoved(1, ev);
+            }
+        }

+                constexpr float threshold = 0.5f;
+                constexpr float interval = 0.06f;
+                static float sDocScrollAccum = interval; // primed so the first deflection scrolls at once
+                if (ry <= -threshold || ry >= threshold)
+                {
+                    sDocScrollAccum += dt;
+                    if (sDocScrollAccum >= interval)
+                    {
+                        sDocScrollAccum = 0.0f;
+                        const int step = (ry < 0.0f) ? 40 : -40; // stick up = view up (positive offset)
+                        for (MWGui::WindowBase* w : scrollWm->getGuiModeWindows(MWGui::GM_Scroll))
+                        {
+                            MyGUI::Widget* widget = w ? w->getControllerScrollWidget() : nullptr;
+                            MyGUI::ScrollView* sv

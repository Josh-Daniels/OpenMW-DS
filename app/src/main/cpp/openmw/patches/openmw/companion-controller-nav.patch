     void ControllerManager::update(float dt)
     {
+#ifdef __ANDROID__
+        // COMPANION: right-stick scroll for DS overlays. SDL emits axis events only on CHANGE, so a
+        // HELD stick can't drive continuous scrolling from the event path — poll the live axis state
+        // each frame instead and emit COMPANION_NAV_SCROLL_* at a throttled cadence while deflected.
+        if (companionNavActive() && MWBase::Environment::get().getWindowManager()->isGuiMode())
+        {
+            const float ry = getAxisValue(SDL_CONTROLLER_AXIS_RIGHTY); // live hardware state, [-1,1)
+            constexpr float threshold = 0.5f;  // ~16000/32768, matches the old event threshold
+            constexpr float interval = 0.06f;  // ~60ms between emitted scroll steps while held
+            static float sScrollAccum = interval; // primed so the first deflection emits immediately
+            if (ry <= -threshold || ry >= threshold)
+            {
+                sScrollAccum += dt;
+                if (sScrollAccum >= interval)
+                {
+                    sScrollAccum = 0.0f;
+                    Log(Debug::Info) << (ry < 0.0f ? "COMPANION_NAV_SCROLL_UP:" : "COMPANION_NAV_SCROLL_DOWN:");
+                }
+            }
+            else
+            {
+                sScrollAccum = interval; // re-arm in the deadzone so the next deflection fires at once
+            }
+
+            // COMPANION: left-stick X drives the barter gold slider — same held-stick problem, same
+            // per-frame poll (reuses threshold/interval above). Negative (left) = decrease, positive
+            // (right) = increase; own accumulator so it's independent of the scroll poll.
+            const float lx = getAxisValue(SDL_CONTROLLER_AXIS_LEFTX);
+            static float sSliderAccum = interval; // primed so the first deflection emits immediately
+            if (lx <= -threshold || lx >= threshold)
+            {
+                sSliderAccum += dt;
+                if (sSliderAccum >= interval)
+                {
+                    sSliderAccum = 0.0f;
+                    Log(Debug::Info) << (lx < 0.0f ? "COMPANION_NAV_SLIDER_LEFT:" : "COMPANION_NAV_SLIDER_RIGHT:");
+                }
+            }
+            else
+            {
+                sSliderAccum = interval; // re-arm in the deadzone
+            }
+
+            // COMPANION: right-stick X scrolls the SPLIT horizontal grids left/right (the vertical
+            // right-stick Y poll above drives the BOTTOM vertical lists up/down). Same per-frame
+            // poll + own accumulator. Negative (left) = scroll left, positive (right) = scroll right.
+            const float rx = getAxisValue(SDL_CONTROLLER_AXIS_RIGHTX);
+            static float sScrollHAccum = interval; // primed so the first deflection emits immediately
+            if (rx <= -threshold || rx >= threshold)
+            {
+                sScrollHAccum += dt;
+                if (sScrollHAccum >= interval)
+                {
+                    sScrollHAccum = 0.0f;
+                    Log(Debug::Info) << (rx < 0.0f ? "COMPANION_NAV_SCROLL_LEFT:" : "COMPANION_NAV_SCROLL_RIGHT:");
+                }
+            }
+            else
+            {
+                sScrollHAccum = interval; // re-arm in the deadzone
+            }
+        }
+#endif

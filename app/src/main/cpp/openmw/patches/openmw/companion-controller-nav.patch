+                            if (sv)
+                                sv->setViewOffset(sv->getViewOffset() + MyGUI::IntPoint(0, step));
+                        }
+                    }
+                }
+                else
+                {
+                    sDocScrollAccum = interval; // re-arm in the deadzone
+                }
+            }
+        }

+                case SDL_CONTROLLER_BUTTON_DPAD_UP:        Log(Debug::Info) << "COMPANION_NAV_UP:";      return true;
+                case SDL_CONTROLLER_BUTTON_DPAD_DOWN:      Log(Debug::Info) << "COMPANION_NAV_DOWN:";    return true;
+                case SDL_CONTROLLER_BUTTON_A:              Log(Debug::Info) << "COMPANION_NAV_CONFIRM:"; return true;

+                case SDL_CONTROLLER_BUTTON_LEFTSHOULDER:   Log(Debug::Info) << "COMPANION_NAV_L1:";      return true;
+                case SDL_CONTROLLER_BUTTON_RIGHTSHOULDER:  Log(Debug::Info) << "COMPANION_NAV_R1:";      return true;
+                case SDL_CONTROLLER_BUTTON_RIGHTSTICK:     Log(Debug::Info) << "COMPANION_NAV_INFO:";    return true;
+                case SDL_CONTROLLER_BUTTON_B:
+                    // Only intercept B while a quantity selector is up — then it CANCELS just the
+                    // selector (COMPANION_NAV_CANCEL) instead of closing the whole overlay. Otherwise
+                    // fall through so B keeps its normal close behaviour.
+                    if (companionQtySelectorOpen()) { Log(Debug::Info) << "COMPANION_NAV_CANCEL:"; return true; }
+                    break;
+                default: break; // B (no selector) and unlisted buttons fall through to vanilla handling
+            }
+        }
+#endif

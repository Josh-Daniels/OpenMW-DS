     void TrainingWindow::setPtr(const MWWorld::Ptr& actor)
     {
         if (actor.isEmpty() || !actor.getClass().isActor())
             throw std::runtime_error("Invalid argument in TrainingWindow::setPtr");
         mPtr = actor;
+
+        sTrainingWindowCompanionOpen = true;
+        Log(Debug::Info) << "COMPANION_TRAINING_OPEN";
 
         MWWorld::Ptr player = MWMechanics::getPlayer();
         int playerGold = player.getClass().getContainerStore(player).count(MWWorld::ContainerStore::sGoldId);
@@ -160,6 +168,21 @@
         MWBase::Environment::get().getWindowManager()->removeGuiMode(GM_Training);
     }
 
+    void TrainingWindow::onClose()
+    {
+        WindowBase::onClose();
+        // COMPANION: emit the close signal only on the real mode-pop (containsMode false),
+        // not on a transient hide, matching TradeWindow::onClose. Lets the bottom-screen
+        // conversation overlay come back once this native window is gone (Vanilla mode).
+        if (sTrainingWindowCompanionOpen
+            && !MWBase::Environment::get().getWindowManager()->containsMode(GM_Training))
+        {
+            sTrainingWindowCompanionOpen = false;
+            Log(Debug::Info) << "COMPANION_TRAINING_CLOSED";
+        }
+    }
+

+// Companion (bottom-screen training): extern "C" bridges driven from drainCompanionCommands
+// (androidmain.cpp, engine main thread). Mirror the repair bridges. Each no-ops unless a training
+// session is actually live (containsMode guard, stale-window safe).
+extern "C" void companionTrainSkill(int index)
+{
+    if (!gCompanionTrainingWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Training))
+        return;
+    gCompanionTrainingWindow->companionTrainByIndex(index);
+}
+
+extern "C" void companionTrainingCancel()
+{
+    if (!gCompanionTrainingWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Training))
+        return;
+    // Pop the mode. In DS mode the window is already hidden, so the mode-pop's setVisible(false) is a
+    // no-op that never fires onClose(); emit the close signal explicitly (once-guarded).
+    MWBase::Environment::get().getWindowManager()->removeGuiMode(MWGui::GM_Training);
+    companionEmitTrainingClosed();
+}

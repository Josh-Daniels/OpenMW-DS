+    void TradeWindow::companionExportModelItems(TradeItemModel* model, const std::string& side)
+    {
+        if (!model)
+            return;
+        // side == "vendor": the player is buying, so price each item at the merchant's
+        // buying offer; side == "player": the player is selling, price at the selling offer.
+        const bool buying = (side == "vendor");
+        const VFS::Manager* const vfs = MWBase::Environment::get().getResourceSystem()->getVFS();
+        const std::size_t itemCount = model->getItemCount();
+        for (std::size_t i = 0; i < itemCount; ++i)
+        {
+            const ItemStack& item = model->getItem(static_cast<int>(i));
+            // Skip items already staged into an offer (Type_Barter) — they are shown as
+            // selected on the bottom screen (tracked optimistically there); re-listing them
+            // as available would double-count them.
+            if (item.mType == ItemStack::Type_Barter)
+                continue;
+            MWWorld::Ptr base = item.mBase;
+            const int stackCount = static_cast<int>(item.mCount);
+            // Base record value — condition-INDEPENDENT, no mercantile/disposition adjustment —
+            // so the bottom-screen list matches vanilla's barter value. getClass().getValue()
+            // handles soul gems (trapped-soul value), player-made potions (getPotionValue) and
+            // gold stacks (1) correctly. The AUTHORITATIVE net the player is actually charged
+            // still comes from getBarterOffer via updateOffer() → COMPANION_BARTER_OFFER.
+            const int unitValue = base.getClass().getValue(base);
+            const std::string refId = base.getCellRef().getRefId().serializeText();
+            const std::string name{ base.getClass().getName(base) };
+            std::string icon;
+            const std::string_view rawIcon = base.getClass().getInventoryIcon(base);
+            if (!rawIcon.empty() && vfs)
+                icon = Misc::ResourceHelpers::correctIconPath(VFS::Path::toNormalized(rawIcon), *vfs);
+            const bool worn = (item.mType == ItemStack::Type_Equipped);
+            // Player-side items are gated by the merchant's services (canSell); vendor
+            // items are already service-filtered, so they are always buyable.
+            const bool sellable
+                = buying ? true : base.getClass().canSell(base, getMerchantServices());
+
+            std::ostringstream out;
+            out << "COMPANION_BARTER_ITEM:{\"side\":\"" << side << "\""
+                << ",\"id\":\"" << companionJsonEscape(refId) << "\""
+                << ",\"sid\":\"" << companionJsonEscape(refId) << "\""
+                << ",\"name\":\"" << companionJsonEscape(name) << "\""
+                << ",\"count\":" << stackCount
+                << ",\"value\":" << unitValue
+                << ",\"cat\":\"" << companionBarterCategory(base) << "\""
+                << ",\"icon\":\"" << companionJsonEscape(icon) << "\""
+                << ",\"sellable\":" << (sellable ? "true" : "false")
+                << ",\"worn\":" << (worn ? "true" : "false") << "}";
+            Log(Debug::Info) << out.str();
+        }
+    }
+
+    void TradeWindow::companionExportOpen()
+    {
+        if (!mTradeModel || mPtr.isEmpty())
+            return;
+        MWWorld::Ptr player = MWMechanics::getPlayer();
+        const int playerGold
+            = player.getClass().getContainerStore(player).count(MWWorld::ContainerStore::sGoldId);
+
+        std::ostringstream header;
+        header << "COMPANION_BARTER_OPEN:{\"vendor\":\"" << companionJsonEscape(mPtr.getClass().getName(mPtr))
+               << "\",\"vendorGold\":" << getMerchantGold() << ",\"playerGold\":" << playerGold << "}";
+        Log(Debug::Info) << header.str();
+
+        // Vendor items first (already service-filtered by TradeItemModel), then the
+        // player's own sellable items. Streamed one small line each (4096-byte flush safety).
+        mTradeModel->update();
+        companionExportModelItems(mTradeModel, "vendor");
+
+        TradeItemModel* playerTradeModel
+            = MWBase::Environment::get().getWindowManager()->getInventoryWindow()->getTradeModel();
+        if (playerTradeModel)
+        {
+            playerTradeModel->update();
+            companionExportModelItems(playerTradeModel, "player");
+        }
+
+        Log(Debug::Info) << "COMPANION_BARTER_END";
+
+        // Force the first offer line to emit (fresh session starts at a zero offer).
+        gCompanionLastBarterOffer.clear();
+        companionExportOffer();
+    }
+
+    void TradeWindow::companionExportOffer()
+    {
+        MWWorld::Ptr player = MWMechanics::getPlayer();
+        const int playerGold
+            = player.getClass().getContainerStore(player).count(MWWorld::ContainerStore::sGoldId);
+
+        // merchantOffer = the fair price (native, authoritative direction); balance = the
+        // actual offer the player is making (= merchantOffer + extraGold), which is what
+        // haggle() ultimately compares. The Kotlin net readout uses `balance`.
+        std::ostringstream out;
+        out << "{\"merchantOffer\":" << mCurrentMerchantOffer << ",\"balance\":" << mCurrentBalance
+            << ",\"extraGold\":" << gCompanionExtraGold << ",\"vendorGold\":" << getMerchantGold()
+            << ",\"playerGold\":" << playerGold << "}";
+        const std::string payload = out.str();
+        if (payload == gCompanionLastBarterOffer)
+            return; // change-detection: unchanged offer prints nothing
+        gCompanionLastBarterOffer = payload;
+        Log(Debug::Info) << "COMPANION_BARTER_OFFER:" << payload;
+    }

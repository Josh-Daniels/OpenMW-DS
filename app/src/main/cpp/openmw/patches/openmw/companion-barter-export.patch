+    int TradeWindow::companionFindIndex(TradeItemModel* model, const std::string& refId, bool borrowed)
+    {
+        if (!model)
+            return -1;
+        // Rebuild mItems so borrowed (Type_Barter) items are enumerated with the current
+        // staged state (TradeItemModel::update appends mBorrowedToUs as Type_Barter). The
+        // returned index is used immediately by the caller with no intervening update.
+        model->update();
+        const std::size_t itemCount = model->getItemCount();
+        for (std::size_t i = 0; i < itemCount; ++i)
+        {
+            const ItemStack& item = model->getItem(static_cast<int>(i));
+            const bool isBorrowed = (item.mType == ItemStack::Type_Barter);
+            if (isBorrowed != borrowed)
+                continue;
+            if (item.mBase.getCellRef().getRefId().serializeText() == refId)
+                return static_cast<int>(i);
+        }
+        return -1;
+    }
+
+    void TradeWindow::companionBorrow(const std::string& side, const std::string& refId, int count)
+    {
+        if (!mTradeModel || count <= 0)
+            return;
+        TradeItemModel* playerTradeModel
+            = MWBase::Environment::get().getWindowManager()->getInventoryWindow()->getTradeModel();
+        if (!playerTradeModel)
+            return;
+
+        if (side == "vendor")
+        {
+            // Player buys a vendor item: borrow it from the merchant to the player
+            // (mirrors sellItem's normal-item branch).
+            const int idx = companionFindIndex(mTradeModel, refId, /*borrowed=*/false);
+            if (idx < 0)
+                return;
+            const std::size_t avail = mTradeModel->getItem(idx).mCount;
+            const std::size_t n = std::min<std::size_t>(static_cast<std::size_t>(count), avail);
+            playerTradeModel->borrowItemToUs(idx, mTradeModel, n);
+            mTradeModel->borrowItemFromUs(idx, n);
+        }
+        else
+        {
+            // Player sells their own item: borrow it from the player to the merchant
+            // (mirrors the standalone borrowItem()).
+            const int idx = companionFindIndex(playerTradeModel, refId, /*borrowed=*/false);
+            if (idx < 0)
+                return;
+            const std::size_t avail = playerTradeModel->getItem(idx).mCount;
+            const std::size_t n = std::min<std::size_t>(static_cast<std::size_t>(count), avail);
+            mTradeModel->borrowItemToUs(idx, playerTradeModel, n);
+        }
+
+        MWBase::Environment::get().getWindowManager()->getInventoryWindow()->updateItemView();
+        mItemView->update();
+        updateOffer();
+        // Preserve the player's manual gold offset across item changes (updateOffer only
+        // shifts the balance by the merchant-offer delta, and resets it to 0 when both
+        // sides are empty). See gCompanionExtraGold.
+        mCurrentBalance = mCurrentMerchantOffer + gCompanionExtraGold;
+        updateLabels();
+        companionExportOffer();
+    }
+
+    void TradeWindow::companionReturn(const std::string& side, const std::string& refId, int count)
+    {
+        if (!mTradeModel || count <= 0)
+            return;
+        TradeItemModel* playerTradeModel
+            = MWBase::Environment::get().getWindowManager()->getInventoryWindow()->getTradeModel();
+        if (!playerTradeModel)
+            return;
+
+        if (side == "vendor")
+        {
+            // Un-stage a bought vendor item: it sits (Type_Barter) in the PLAYER model,
+            // borrowed from the merchant to the player.
+            const int idx = companionFindIndex(playerTradeModel, refId, /*borrowed=*/true);
+            if (idx < 0)
+                return;
+            const std::size_t held = playerTradeModel->getItem(idx).mCount;
+            const std::size_t n = std::min<std::size_t>(static_cast<std::size_t>(count), held);
+            playerTradeModel->returnItemBorrowedToUs(idx, n);
+            mTradeModel->returnItemBorrowedFromUs(idx, playerTradeModel, n);
+        }
+        else
+        {
+            // Un-stage a sold player item: it sits (Type_Barter) in the MERCHANT model,
+            // borrowed from the player to the merchant (mirrors sellItem's Type_Barter branch).
+            const int idx = companionFindIndex(mTradeModel, refId, /*borrowed=*/true);
+            if (idx < 0)
+                return;
+            const std::size_t held = mTradeModel->getItem(idx).mCount;
+            const std::size_t n = std::min<std::size_t>(static_cast<std::size_t>(count), held);
+            mTradeModel->returnItemBorrowedToUs(idx, n);
+            playerTradeModel->returnItemBorrowedFromUs(idx, mTradeModel, n);
+        }
+
+        MWBase::Environment::get().getWindowManager()->getInventoryWindow()->updateItemView();
+        mItemView->update();
+        updateOffer();
+        mCurrentBalance = mCurrentMerchantOffer + gCompanionExtraGold;
+        updateLabels();
+        companionExportOffer();
+    }
+
+    void TradeWindow::companionSetExtraGold(int extra)
+    {
+        gCompanionExtraGold = extra;
+        mCurrentBalance = mCurrentMerchantOffer + gCompanionExtraGold;
+        updateLabels();

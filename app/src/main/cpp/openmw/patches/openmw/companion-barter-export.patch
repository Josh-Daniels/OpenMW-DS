+extern "C" void companionBarterReturn(const char* side, const char* refId, int count)
+{
+    if (!gCompanionTradeWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Barter))
+        return;
+    gCompanionTradeWindow->companionReturn(side ? side : "", refId ? refId : "", count);
+}

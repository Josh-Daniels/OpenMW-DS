+    // JSON-escape a string for a COMPANION_BARTER_* payload. Inventory icon paths
+    // contain backslashes and item names can contain quotes, so both must be escaped.
+    std::string companionJsonEscape(std::string_view s)
+    {
+        std::string out;
+        out.reserve(s.size() + 8);
+        for (const char c : s)
+        {
+            switch (c)
+            {
+                case '"': out += "\\\""; break;
+                case '\\': out += "\\\\"; break;
+                case '\n': out += "\\n"; break;
+                case '\r': out += "\\r"; break;
+                case '\t': out += "\\t"; break;
+                default: out += c; break;
+            }
+        }
+        return out;
+    }

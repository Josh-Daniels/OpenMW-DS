+// Companion (bottom-screen barter): extern "C" bridges driven from drainCompanionCommands
+// (androidmain.cpp, engine main thread). Mirror the dialogue/persuasion bridges. Each
+// no-ops unless a barter session is actually live (containsMode guard, stale-window safe).
+extern "C" void companionBarterBorrow(const char* side, const char* refId, int count)
+{
+    if (!gCompanionTradeWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Barter))
+        return;
+    gCompanionTradeWindow->companionBorrow(side ? side : "", refId ? refId : "", count);
+}

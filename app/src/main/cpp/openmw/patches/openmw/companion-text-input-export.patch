+#ifdef __ANDROID__
+    // COMPANION: the MyGUI EditBox that currently holds key focus (name / class /
+    // save-name entry), captured in onKeyFocusChanged below. companionSetFocusedText()
+    // writes the bottom-screen Android-keyboard panel's confirmed text back into it, and
+    // it is cleared when focus leaves the field. Engine (MyGUI) thread only.
+    static MyGUI::EditBox* gCompanionTextInput = nullptr;
+    // COMPANION: called from drainCompanionCommands (androidmain.cpp) on the engine main
+    // thread when the bottom-screen input panel CONFIRMS (OK / Done / keyboard dismissed).
+    // Fills the focused EditBox's caption (more reliable than replaying SDL text events), then
+    // ACCEPTS the dialog by injecting Return into it — exactly as a physical Enter would —
+    // firing eventEditSelectAccept -> onOkClicked -> eventDone so the modal closes and character
+    // creation advances. We deliberately do NOT clear key focus: OpenMW's text dialogs are modal
+    // and re-grab a cleared field on the very next frame (confirmed by a COMPANION_TEXT_INPUT_OPEN
+    // arriving 1ms after every CLOSED), so the only way the field actually goes away is to close
+    // its dialog. Closing changes key focus -> onKeyFocusChanged(nullptr) ->
+    // COMPANION_TEXT_INPUT_CLOSED, which dismisses the panel and resets gCompanionTextInput. This
+    // is the same injectKeyPress(Return) actionmanager.cpp uses to trigger OK in GUI mode. MyGUI
+    // is single-threaded, so this MUST run on the engine thread. extern "C" so the symbol is
+    // reachable from androidmain.cpp without a header (C linkage ignores the enclosing namespace).
+    extern "C" void companionSetFocusedText(const char* utf8)
+    {
+        if (!gCompanionTextInput || !utf8)
+            return;
+        gCompanionTextInput->setCaption(MyGUI::UString(utf8));
+        MWBase::Environment::get().getWindowManager()->injectKeyPress(MyGUI::KeyCode::Return, 0, false);
+    }
+    // COMPANION: called when the bottom-screen input panel CANCELS (Cancel button / tap-away):
+    // discard the edit by injecting Escape, which routes through exitCurrentGuiMode and closes/
+    // backs out the modal (merely clearing focus would just be re-grabbed by the modal, same as
+    // above). The resulting focus change emits COMPANION_TEXT_INPUT_CLOSED and dismisses the panel.
+    extern "C" void companionCancelTextInput()
+    {
+        if (!gCompanionTextInput)
+            return;
+        MWBase::Environment::get().getWindowManager()->injectKeyPress(MyGUI::KeyCode::Escape, 0, false);
+    }
+#endif

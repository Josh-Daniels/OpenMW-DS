+
+// Companion bottom-screen dialogue bridge. Called from drainCompanionCommands()
+// (androidmain.cpp) on the engine main thread, so touching MyGUI here is safe.
+// Both are no-ops unless a dialogue is actually open, guarding against a stale
+// mPtr (the DialogueWindow object outlives any single conversation).
+extern "C" void companionDialogueSelectEntry(const char* entry)
+{
+    if (!gCompanionDialogueWindow || !entry)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Dialogue))
+        return;
+    gCompanionDialogueWindow->companionSelectEntry(entry);
+}
+
+extern "C" void companionDialogueGoodbye()
+{
+    if (!gCompanionDialogueWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Dialogue))
+        return;
+    gCompanionDialogueWindow->companionGoodbye();
+}
+
+extern "C" void companionDialogueChoice(int id)
+{
+    if (!gCompanionDialogueWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Dialogue))
+        return;
+    gCompanionDialogueWindow->companionSelectChoice(id);
+}
+
+extern "C" void companionPersuade(int type)
+{
+    if (!gCompanionDialogueWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_Dialogue))
+        return;
+    gCompanionDialogueWindow->companionPersuade(type);
+}

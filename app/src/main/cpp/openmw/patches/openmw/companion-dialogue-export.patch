+    void DialogueWindow::companionSelectEntry(const std::string& entry)
+    {
+        // Programmatic equivalent of a mouse click on a topic OR service row. Route
+        // through the same handler the click uses: onSelectListItem() already dispatches
+        // service GMST strings to their windows and everything else to onTopicActivated(),
+        // and applies the mGoodbye / isInChoice guards internally.
+        onSelectListItem(entry, 0);
     }
 
+    void DialogueWindow::companionGoodbye()
+    {
+        // Goodbye is NOT a topic — mirror onByeClicked(): exit() runs goodbyeSelected()
+        // (unless mid-choice, in which case it's refused), then pop the dialogue mode.
+        // But when the companion (bottom) screen drives Goodbye while Hide UI has hidden
+        // this window, exit()'s mTopicsList->scrollToTop() runs on a hidden MyGUI widget;
+        // do exit()'s non-UI work directly instead (mirroring its else-branch minus the
+        // scroll) so the conversation still ends cleanly. The isInChoice guard mirrors
+        // exit() refusing (returning false) mid-choice.
+        if (!isVisible())
+        {
+            MWBase::DialogueManager* dialogueManager = MWBase::Environment::get().getDialogueManager();
+            if (!dialogueManager->isInChoice())
+            {
+                resetReference();
+                dialogueManager->goodbyeSelected();
+                MWBase::Environment::get().getWindowManager()->removeGuiMode(GM_Dialogue);
+                // onClose() won't fire here: the window is already hidden, so the mode-pop's
+                // setVisible(false) is a no-op and skips the visible->hidden transition that
+                // normally emits COMPANION_DIALOGUE_CLOSED. Emit it explicitly, or the
+                // companion overlay never clears its topic/service/history state.
+                Log(Debug::Info) << "COMPANION_DIALOGUE_CLOSED";
+            }
+            return;
+        }
+        if (exit())
+            MWBase::Environment::get().getWindowManager()->removeGuiMode(GM_Dialogue);
+    }
+
+    void DialogueWindow::companionSelectChoice(int id)
+    {
+        // Programmatic equivalent of clicking a choice/question answer. onChoiceActivated
+        // is protected, so this public wrapper exists for the companion bridge; it does
+        // exactly what a choice-link click does (questionAnswered + updateTopics, or a
+        // Goodbye choice).
+        onChoiceActivated(id);
+    }
+
+    void DialogueWindow::companionPersuade(int type)
+    {
+        // Companion: drive a persuasion action from the bottom-screen popup without ever
+        // showing the native PersuasionDialog modal. Mirrors PersuasionDialog::onPersuade
+        // (persuade + updateTopics) using this window's own response callback so the result
+        // line lands in the shared history; the disposition bar refreshes via onFrame.
+        MWBase::MechanicsManager::PersuasionType t;
+        switch (type)
+        {
+            case 0: t = MWBase::MechanicsManager::PT_Admire; break;
+            case 1: t = MWBase::MechanicsManager::PT_Intimidate; break;
+            case 2: t = MWBase::MechanicsManager::PT_Taunt; break;
+            case 3: t = MWBase::MechanicsManager::PT_Bribe10; break;
+            case 4: t = MWBase::MechanicsManager::PT_Bribe100; break;
+            default: t = MWBase::MechanicsManager::PT_Bribe1000; break;
+        }
+        // Affordability guard for bribes (the native modal disables unaffordable buttons).
+        MWWorld::Ptr player = MWMechanics::getPlayer();
+        const int gold = player.getClass().getContainerStore(player).count(MWWorld::ContainerStore::sGoldId);
+        if ((t == MWBase::MechanicsManager::PT_Bribe10 && gold < 10)
+            || (t == MWBase::MechanicsManager::PT_Bribe100 && gold < 100)
+            || (t == MWBase::MechanicsManager::PT_Bribe1000 && gold < 1000))
+            return;
+        MWBase::Environment::get().getDialogueManager()->persuade(t, mCallback.get());
+        mCallback->updateTopics();
+    }

+
+// Companion (bottom-screen spell buying): extern "C" bridges driven from drainCompanionCommands
+// (androidmain.cpp, engine main thread). Mirror the repair bridges. Each no-ops unless a spell-buying
+// session is actually live (containsMode guard, stale-window safe).
+extern "C" void companionBuySpell(int index)
+{
+    if (!gCompanionSpellBuyingWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_SpellBuying))
+        return;
+    gCompanionSpellBuyingWindow->companionBuySpellByIndex(index);
+}
+
+extern "C" void companionSpellBuyingCancel()
+{
+    if (!gCompanionSpellBuyingWindow)
+        return;
+    if (!MWBase::Environment::get().getWindowManager()->containsMode(MWGui::GM_SpellBuying))
+        return;
+    // Pop the mode. In DS mode the window is already hidden, so the mode-pop's setVisible(false) is a
+    // no-op that never fires onClose(); emit the close signal explicitly (once-guarded).
+    MWBase::Environment::get().getWindowManager()->removeGuiMode(MWGui::GM_SpellBuying);
+    companionEmitSpellBuyingClosed();
+}

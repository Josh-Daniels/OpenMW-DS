+    void SpellBuyingWindow::onClose()
+    {
+        WindowBase::onClose();
+        // COMPANION: real-close emit (Vanilla visible->hidden). Guarded by !containsMode so a transient
+        // hide doesn't fire it. DS-hidden closes never reach here — those emit via the cancel bridge /
+        // exit() / onReferenceUnavailable.
+        if (gCompanionSpellBuyingSessionOpen
+            && !MWBase::Environment::get().getWindowManager()->containsMode(GM_SpellBuying))
+            companionEmitSpellBuyingClosed();
+    }
+
+    bool SpellBuyingWindow::exit()
+    {
+        // COMPANION: B/Escape close. In DS mode the window is hidden so onClose() won't fire on the
+        // following mode-pop — emit explicitly (once-guarded; no double with onClose in Vanilla).
+        companionEmitSpellBuyingClosed();
+        return true;
+    }
+
+    // COMPANION (bottom-screen spell buying): the merchant-adjusted price for one spell. Same formula
+    // as addSpell() (calcSpellCost x fSpellValueMult, floored at 1, then getBarterOffer) so the exported
+    // cost and the bridge's affordability check agree with the native window. getBarterOffer is native-
+    // only — the reason this whole flow must be a native bridge (same as Repair/Barter).
+    int SpellBuyingWindow::companionSpellPrice(const ESM::Spell& spell) const
+    {
+        const MWWorld::ESMStore& store = *MWBase::Environment::get().getESMStore();
+        int price = std::max(1,
+            static_cast<int>(MWMechanics::calcSpellCost(spell)
+                * store.get<ESM::GameSetting>().find("fSpellValueMult")->mValue.getFloat()));
+        return MWBase::Environment::get().getMechanicsManager()->getBarterOffer(mPtr, price, true);
+    }
+
+    // COMPANION: stream the spell-buying session to the bottom screen. Unlike the native list (which
+    // hides spells the player already knows), this includes known spells with known=1 so the overlay
+    // can show them greyed ("Already known"). index = ordinal in THIS list, stable while the sim is
+    // paused under GM_SpellBuying; a purchase only flips a spell's known flag (it keeps its slot), so
+    // the index survives the re-export. Streamed one small line each (4096-byte flush safety).
+    void SpellBuyingWindow::companionExportOpen()
+    {
+        if (mPtr.isEmpty())
+            return;
+
+        MWWorld::Ptr player = MWMechanics::getPlayer();
+        const int playerGold
+            = player.getClass().getContainerStore(player).count(MWWorld::ContainerStore::sGoldId);
+
+        gCompanionSpellBuyingSessionOpen = true;
+        Log(Debug::Info) << "COMPANION_SPELLBUYING_OPEN:"
+                         << companionSpellBuyingSanitize(mPtr.getClass().getName(mPtr));
+        Log(Debug::Info) << "COMPANION_PLAYER_GOLD:" << playerGold;
+
+        mCompanionSpellIds.clear();
+
+        // Same eligibility filter as the native setPtr EXCEPT we keep spells the player already knows.
+        MWMechanics::Spells& merchantSpells = mPtr.getClass().getCreatureStats(mPtr).getSpells();
+        std::vector<const ESM::Spell*> spellsToSort;
+        for (const ESM::Spell* spell : merchantSpells)
+        {
+            if (spell->mData.mType != ESM::Spell::ST_Spell)
+                continue; // don't sell diseases, curses or powers
+            if (mPtr.getClass().isNpc())
+            {
+                const ESM::Race* race = MWBase::Environment::get().getESMStore()->get<ESM::Race>().find(
+                    mPtr.get<ESM::NPC>()->mBase->mRace);
+                if (race->mPowers.exists(spell->mId))
+                    continue;
+            }
+            spellsToSort.push_back(spell);
+        }
+        std::stable_sort(spellsToSort.begin(), spellsToSort.end(), sortSpells);
+
+        const MWWorld::ESMStore& store = *MWBase::Environment::get().getESMStore();
+        for (std::size_t i = 0; i < spellsToSort.size(); ++i)
+        {
+            const ESM::Spell* spell = spellsToSort[i];
+            const bool known = playerHasSpell(spell->mId);
+            const int price = companionSpellPrice(*spell);
+
+            // school = the spell's effective (governing-skill) school name, e.g. "Destruction".
+            std::string school;
+            const ESM::RefId schoolSkill = MWMechanics::getSpellSchool(spell, player);
+            if (const ESM::Skill* sk = store.get<ESM::Skill>().search(schoolSkill))
+                school = sk->mName;
+
+            Log(Debug::Info) << "COMPANION_SPELLBUYING_SPELL:" << i << "|"
+                             << companionSpellBuyingSanitize(spell->mName) << "|"
+                             << companionSpellBuyingSanitize(school) << "|" << price << "|" << (known ? 1 : 0) << "|" << spell->mId.serializeText();
+            mCompanionSpellIds.push_back(spell->mId);
+        }
+        Log(Debug::Info) << "COMPANION_SPELLBUYING_END";
+    }
+
+    // COMPANION: buy the spell at the given ordinal in the exported list. Driven from the
+    // companionBuySpell bridge (drainCompanionCommands). Mirrors onSpellButtonClick, then re-exports.
+    void SpellBuyingWindow::companionBuySpellByIndex(int index)
+    {
+        if (index < 0 || index >= static_cast<int>(mCompanionSpellIds.size()))
+            return;
+        const ESM::RefId spellId = mCompanionSpellIds[index];
+
+        if (playerHasSpell(spellId))
+            return; // already known — nothing to buy
+
+        const MWWorld::ESMStore& store = *MWBase::Environment::get().getESMStore();
+        const ESM::Spell* spell = store.get<ESM::Spell>().search(spellId);
+        if (!spell)
+            return;
+
+        MWWorld::Ptr player = MWMechanics::getPlayer();
+        const int price = companionSpellPrice(*spell);
+        if (price > player.getClass().getContainerStore(player).count(MWWorld::ContainerStore::sGoldId))
+            return; // can't afford — engine-style silent reject
+
+        player.getClass().getCreatureStats(player).getSpells().add(spellId);
+        player.getClass().getContainerStore(player).remove(MWWorld::ContainerStore::sGoldId, price);
+        MWMechanics::CreatureStats& npcStats = mPtr.getClass().getCreatureStats(mPtr);
+        npcStats.setGoldPool(npcStats.getGoldPool() + price);
+        MWBase::Environment::get().getWindowManager()->playSound(ESM::RefId::stringRefId("Item Gold Up"));
+
+        setPtr(mPtr, mSpellsView->getViewOffset().top); // rebuild native list + re-export to bottom screen
+    }

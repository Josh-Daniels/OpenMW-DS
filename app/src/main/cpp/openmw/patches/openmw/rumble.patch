diff --git a/files/data/scripts/omw/input/gamepadcontrols.lua b/files/data/scripts/omw/input/gamepadcontrols.lua
index 7a1396c0ec..4f46c87ab3 100644
--- a/files/data/scripts/omw/input/gamepadcontrols.lua
+++ b/files/data/scripts/omw/input/gamepadcontrols.lua
@@ -1,4 +1,90 @@
 local input = require('openmw.input')
+local async = require('openmw.async')
+local core = require('openmw.core')
+
+local activeRumbles = {}
+local currentChannel = nil
+local generationCounter = 0
+
+local function clamp01(value)
+    if value == nil then
+        return nil
+    end
+    local number = tonumber(value)
+    if not number then
+        return nil
+    end
+    if number < 0.0 then
+        return 0.0
+    end
+    if number > 1.0 then
+        return 1.0
+    end
+    return number
+end
+
+local function resolveChannel(argument, stackOffset)
+    if type(argument) == 'table' then
+        local channel = argument.channel or argument.id or argument.tag
+        if channel ~= nil then
+            return tostring(channel)
+        end
+    elseif argument ~= nil then
+        return tostring(argument)
+    end
+    local info = debug.getinfo(stackOffset or 2, 'S')
+    if info and info.source then
+        return info.source
+    end
+    return '<unknown>'
+end
+
+local function applyCurrentRumble()
+    local now = core.getSimulationTime()
+    local bestId, bestEntry
+    for id, entry in pairs(activeRumbles) do
+        if entry.expiresAt <= now then
+            activeRumbles[id] = nil
+        elseif not bestEntry or entry.startedAt > bestEntry.startedAt then
+            bestId = id
+            bestEntry = entry
+        end
+    end
+
+    if not bestEntry then
+        if currentChannel ~= nil then
+            currentChannel = nil
+            input.controllerStopRumble()
+        end
+        return
+    end
+
+    currentChannel = bestId
+    local remaining = math.max(bestEntry.expiresAt - now, 0.001)
+    input.controllerStartRumble {
+        duration = remaining,
+        low = bestEntry.low,
+        high = bestEntry.high,
+    }
+end
+
+local stopTimer = async:registerTimerCallback('GamepadControlsStopRumble', function(payload)
+    if type(payload) ~= 'table' then
+        return
+    end
+    local id = payload.id
+    local generation = payload.generation
+    local entry = id and activeRumbles[id]
+    if not entry or entry.generation ~= generation then
+        return
+    end
+
+    activeRumbles[id] = nil
+    if currentChannel == id then
+        currentChannel = nil
+    end
+    applyCurrentRumble()
+end)
 
 return {
 
@@ -43,16 +129,68 @@ return {
 
         --- Trigger a rumble effect on the active controller.
         -- @function [parent=#GamepadControls] startRumble
-        -- @param options Table passed to @{openmw.input#controllerStartRumble}.
+        -- @param options Table passed to @{openmw.input#controllerStartRumble}. May include a `channel`/`id`/`tag`
+        --   field to distinguish multiple concurrent rumble requests.
         -- @return #boolean ``true`` if rumble started, ``false`` otherwise.
         startRumble = function(options)
-            return input.controllerStartRumble(options)
+            if type(options) ~= 'table' then
+                error('startRumble expects an options table', 2)
+            end
+            if not input.controllerHasRumble() then
+                return false
+            end
+
+            local duration = tonumber(options.duration)
+            if not duration or duration <= 0 then
+                error('startRumble requires options.duration > 0', 2)
+            end
+
+            local low = options.low
+            local high = options.high
+            local strength = options.strength
+            if low == nil and high == nil then
+                low = strength
+                high = strength
+            elseif low == nil then
+                low = high
+            elseif high == nil then
+                high = low
+            end
+
+            low = clamp01(low)
+            high = clamp01(high)
+            if low == nil or high == nil then
+                error('startRumble requires strength, low, or high to be a number', 2)
+            end
+
+            local channel = resolveChannel(options, 3)
+            local startTime = core.getSimulationTime()
+            generationCounter = generationCounter + 1
+            activeRumbles[channel] = {
+                low = low,
+                high = high,
+                startedAt = startTime,
+                expiresAt = startTime + duration,
+                generation = generationCounter,
+            }
+            async:newSimulationTimer(duration, stopTimer, { id = channel, generation = generationCounter })
+            applyCurrentRumble()
+            return true
         end,
 
-        --- Stop any active controller rumble effect.
+        --- Stop any active controller rumble effect started on the given channel.
         -- @function [parent=#GamepadControls] stopRumble
-        stopRumble = function()
-            input.controllerStopRumble()
+        -- @param[opt] channel Identifier used when starting rumble. Defaults to the calling script.
+        stopRumble = function(channel)
+            local id = resolveChannel(channel, 3)
+            local entry = activeRumbles[id]
+            if entry then
+                activeRumbles[id] = nil
+                if currentChannel == id then
+                    currentChannel = nil
+                    applyCurrentRumble()
+                end
+            end
         end,
     }
 }

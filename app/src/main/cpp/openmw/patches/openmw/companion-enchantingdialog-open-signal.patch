@@ -12,6 +12,8 @@
 #include <components/widgets/list.hpp>
 
 #include <components/esm3/loadgmst.hpp>
+
+#include <components/debug/debuglog.hpp>
 
 #include "../mwbase/environment.hpp"
 #include "../mwbase/mechanicsmanager.hpp"
@@ -146,10 +148,16 @@
         }
     }
 
+    // COMPANION: true between COMPANION_ENCHANTING_OPEN and _CLOSED (Vanilla-only window).
+    static bool sEnchantingDialogCompanionOpen = false;
+
     void EnchantingDialog::setPtr(const MWWorld::Ptr& ptr)
     {
         if (ptr.isEmpty() || (ptr.getType() != ESM::REC_MISC && !ptr.getClass().isActor()))
             throw std::runtime_error("Invalid argument in EnchantingDialog::setPtr");
+
+        sEnchantingDialogCompanionOpen = true;
+        Log(Debug::Info) << "COMPANION_ENCHANTING_OPEN";
 
         mName->setCaption({});
 
@@ -202,6 +210,21 @@
     {
         MWBase::Environment::get().getWindowManager()->removeGuiMode(GM_Enchanting);
     }
+
+    void EnchantingDialog::onClose()
+    {
+        WindowBase::onClose();
+        // COMPANION: emit the close signal only on the real mode-pop (containsMode false),
+        // not on a transient hide, matching TradeWindow::onClose. Lets the bottom-screen
+        // conversation overlay come back once this native window is gone (Vanilla mode).
+        if (sEnchantingDialogCompanionOpen
+            && !MWBase::Environment::get().getWindowManager()->containsMode(GM_Enchanting))
+        {
+            sEnchantingDialogCompanionOpen = false;
+            Log(Debug::Info) << "COMPANION_ENCHANTING_CLOSED";
+        }
+    }
+
 
     void EnchantingDialog::onSelectItem(MyGUI::Widget* /*sender*/)
     {

+        // container theft (full detection), alarm=false for the pickpocket success path (flag only).
+        player["_runStandardItemTaken"] = [](const Object& o, const Object& item,
+                                              const sol::optional<Object>& container, int count, bool alarm) {
+            verifyPlayer(o);
+            if (!o.isGObject())
+                throw std::runtime_error("Only global scripts can flag stolen items");
+            MWWorld::Ptr containerPtr;
+            if (container.has_value())
+                containerPtr = container->ptrOrEmpty();
+            MWBase::Environment::get().getMechanicsManager()->itemTaken(
+                o.ptr(), item.ptr(), containerPtr, count, alarm);
+        };
 

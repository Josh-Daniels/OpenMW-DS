+
+        // Companion map-only signature: the Map window is visible and the other three inventory
+        // tabs are hidden (disabledByLua via the windows={'Map'} filter). A normal all-tabs native
+        // inventory open shows all four, so this is false there -- leaving vanilla's last-active-tab
+        // restore untouched. This also makes a stale request (e.g. a close toggle, or an open
+        // suppressed by the char-gen guard) harmless: the next all-tabs native open just consumes
+        // it without repositioning anything.
+        const bool mapOnly = mMap && mMap->isVisible()
+            && (!mInventoryWindow || !mInventoryWindow->isVisible())
+            && (!mSpellWindow || !mSpellWindow->isVisible())
+            && (!mStatsWindow || !mStatsWindow->isVisible());
+
+        // Force the Map to be the active controller window so MapWindow::setActiveControllerWindow
+        // repositions it on-screen (it parks the map off-screen at y=viewSize.height+1 while
+        // inactive). The vanilla decrement-then-cycle mode-entry logic in pushGuiMode skips this
+        // exactly when the stored tab was Inventory (index 1): the decrement 1->0 lands on the
+        // computed active index (0=Map) so its != guard sees no change and never calls
+        // setActiveControllerWindow -- leaving the map open-but-off-screen. Only act when the map is
+        // not ALREADY the active window, so the cases the cycle logic already handled correctly
+        // (last tab Map/Spells/Stats) don't get a redundant reposition + "Menu Size" sound.
+        if (mapOnly && Settings::gui().mControllerMenus && !mMap->isActiveControllerWindow())
